# Copia este archivo a `.env` y rellena los valores reales.
# `.env` esta git-ignorado. NUNCA lo commitees.

# Supabase (proyecto bd_odesocan)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt>
SUPABASE_SCHEMA=recursos
SUPABASE_TABLE=entidades

# Mapbox (geocoding primario)
MAPBOX_ACCESS_TOKEN=<mapbox-public-token>

# User-Agent para Nominatim (politica OSM)
MAPA_RECURSOS_UA=MapaRecursosObservatorio/2.0 (investigacion@odesocan.org)
